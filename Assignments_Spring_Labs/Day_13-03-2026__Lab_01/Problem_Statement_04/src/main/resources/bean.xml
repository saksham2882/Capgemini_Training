<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->

    <bean id="employee1" class="com.cg.bean.Employee">
        <property name="employeeId" value="101"/>
        <property name="employeeName" value="Harry"/>
        <property name="salary" value="40000"/>
        <property name="age" value="30"/>
        <property name="businessUnit" ref="sbu"/>
    </bean>

    <bean id="employee2" class="com.cg.bean.Employee">
        <property name="employeeId" value="124"/>
        <property name="employeeName" value="John"/>
        <property name="salary" value="54000"/>
        <property name="age" value="36"/>
        <property name="businessUnit" ref="sbu"/>
    </bean>

    <bean id="sbu" class="com.cg.bean.SBU">
        <property name="sbuCode" value="PES-BU" />
        <property name="sbuName" value="Product Engineering Services" />
        <property name="sbuHead" value="Kim" />

        <property name="empList">
            <list>
                <ref bean="employee1" />
                <ref bean="employee2" />
            </list>
        </property>
    </bean>
</beans>